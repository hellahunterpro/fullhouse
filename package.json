{
  "name": "fullhouse",
  "private": true,
  "workspaces": [
    "worker",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,yellow \"npm run dev --workspace=web\" \"npm run dev --workspace=worker\"",
    "dev:web": "npm run dev --workspace=web",
    "dev:worker": "npm run dev --workspace=worker",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint --no-error-on-unmatched-pattern . --ext .ts,.tsx",
    "format": "prettier --check .",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "deploy": "npm run build --workspace web && (cd worker && npx wrangler deploy)"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
