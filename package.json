{
  "name": "fullhouse",
  "private": true,
  "workspaces": [
    "packages/core",
    "worker",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,yellow \"npm run dev --workspace=web\" \"npm run dev --workspace=worker\"",
    "dev:web": "npm run dev --workspace=web",
    "dev:worker": "npm run dev --workspace=worker",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint --no-error-on-unmatched-pattern . --ext .ts,.tsx",
    "format": "prettier --check .",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspace web && npm run bundle:worker && npm run check:bundle",
    "check:bundle": "node scripts/check-bundle.mjs",
    "deploy": "npm run build --workspace web && (cd worker && npx wrangler deploy)",
    "bundle:worker": "node scripts/gen-bootstrap.mjs && esbuild worker/src/index.ts --bundle --format=esm --target=es2022 --outfile=web/dist/_worker.js --log-level=warning"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^10.0.3",
    "esbuild": "^0.24.2",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
