{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git init*)",
      "Bash(git config *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch *)",
      "Bash(git switch *)",
      "Bash(git checkout -b *)",
      "Bash(git remote *)",
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Bash(wrangler deploy*)",
      "Bash(npx wrangler deploy*)",
      "Bash(npx wrangler pages deploy*)",
      "Bash(npx wrangler d1 * --remote*)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(.dev.vars)"
    ]
  }
}
